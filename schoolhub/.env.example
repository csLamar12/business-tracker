# ---------------------------------------------------------------------------
# SchoolHub Jamaica — environment configuration
# Copy this file to `.env` and adjust as needed.
# ---------------------------------------------------------------------------

# The platform's root domain. Tenant school sites live on subdomains of this.
#   Dev (temporary):  anchorpointja.com
#   Production:       schoolhubja.com
# Locally the app also auto-detects "localhost" so you can visit
#   http://kingston-college.localhost:3000
# NOTE: this is a build-time variable (NEXT_PUBLIC_*). On Cloudflare it must be
# set as a *build* environment variable, not just a runtime secret.
NEXT_PUBLIC_ROOT_DOMAIN=anchorpointja.com

# Database — MongoDB.
#   Local dev / seeding (direct connection to a MongoDB replica set):
#     DATABASE_URL="mongodb://127.0.0.1:27017/schoolhub?replicaSet=rs0&directConnection=true"
#   MongoDB Atlas (direct):
#     DATABASE_URL="mongodb+srv://USER:PASS@cluster.mongodb.net/schoolhub?retryWrites=true&w=majority"
#   Cloudflare Workers (via Prisma Accelerate — see docs/DEPLOYMENT.md):
#     DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=..."
# Prisma + MongoDB requires a replica set (Atlas clusters are replica sets by
# default; for local dev use the helper: `npm run db:local` in another terminal).
DATABASE_URL="mongodb://127.0.0.1:27017/schoolhub?replicaSet=rs0&directConnection=true"

# Secret used to sign admin session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"

# Credentials for the seeded platform super-admin (created by `npm run db:seed`).
SUPERADMIN_EMAIL="admin@schoolhubja.com"
SUPERADMIN_PASSWORD="changeme123"
