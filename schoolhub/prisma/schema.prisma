// SchoolHub Jamaica — data model (MongoDB)
//
// Runs on MongoDB so it can be deployed on Cloudflare Workers (via Prisma
// Accelerate — see lib/db.ts and docs/DEPLOYMENT.md). For MongoDB, Prisma
// emulates referential integrity in the client (relationMode = "prisma"), so
// the `onDelete: Cascade` rules below are enforced by Prisma, not the database.
//
// "Enum-like" fields (plan, role, calendar category) are stored as plain
// strings and validated in the app layer (lib/constants.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenant: one document per school
// ---------------------------------------------------------------------------
model School {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  subdomain String  @unique // e.g. "kingston-college" -> kingston-college.<root domain>
  // Premium plan only. Stored normalized (lowercase, no scheme), e.g. "www.kc.edu.jm"
  customDomain String? @unique
  plan      String  @default("STANDARD") // STANDARD | PREMIUM  (see lib/constants.ts)
  published Boolean @default(false)

  // Branding / identity
  tagline        String?
  motto          String?
  aboutHtml      String? // simple HTML/markdown-ish body shown on the About section
  logoUrl        String?
  heroImageUrl   String?
  primaryColor   String  @default("#0a4d8c")
  secondaryColor String  @default("#f5a623")

  // Contact / location
  principalName String?
  foundedYear   Int?
  addressLine   String?
  parish        String?
  phone         String?
  email         String?

  // Socials
  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  youtubeUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  announcements Announcement[]
  events        Event[]
  calendar      CalendarEntry[]
  staff         StaffMember[]
  achievements  Achievement[]
  alumni        AlumniProfile[]
  admissions    AdmissionsInfo?

  @@index([plan])
}

// ---------------------------------------------------------------------------
// Auth: platform super-admins (schoolId null) and per-school admins/editors
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("SCHOOL_ADMIN") // SUPERADMIN | SCHOOL_ADMIN | EDITOR
  schoolId     String?  @db.ObjectId
  school       School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([schoolId])
}

// ---------------------------------------------------------------------------
// Content types
// ---------------------------------------------------------------------------
model Announcement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  body        String
  pinned      Boolean  @default(false)
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model Event {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String    @db.ObjectId
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  imageUrl    String?
  published   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
}

model CalendarEntry {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String    @db.ObjectId
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String    @default("OTHER") // TERM | HOLIDAY | EXAM | SPORTS | PTA | OTHER
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
}

model StaffMember {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId   String   @db.ObjectId
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name       String
  title      String
  department String?
  bio        String?
  email      String?
  photoUrl   String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId])
}

model Achievement {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String    @db.ObjectId
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  studentName String?
  description String?
  category    String? // e.g. Academics, Sports, Arts, CSEC, CAPE
  achievedOn  DateTime?
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([schoolId])
}

model AlumniProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  gradYear    Int?
  email       String?
  currentRole String?
  message     String?
  approved    Boolean  @default(false) // alumni self-register; an admin approves before it shows publicly
  createdAt   DateTime @default(now())

  @@index([schoolId])
}

model AdmissionsInfo {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId         String    @unique @db.ObjectId
  school           School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  introHtml        String?
  requirementsHtml String?
  processHtml      String?
  feesHtml         String?
  applyUrl         String?
  opensOn          DateTime?
  closesOn         DateTime?
  updatedAt        DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Platform-level lead capture from the marketing site contact form
// ---------------------------------------------------------------------------
model ContactMessage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String
  schoolName String?
  phone      String?
  plan       String? // which plan they're interested in (STANDARD | PREMIUM)
  message    String
  handled    Boolean  @default(false)
  createdAt  DateTime @default(now())
}
